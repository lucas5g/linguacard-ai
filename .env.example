# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls in Next.js.
NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: Required for Prisma to connect to PostgreSQL.
# Example: "postgresql://user:password@localhost:5432/mydb?schema=public"
DATABASE_URL="MY_DATABASE_URL"
