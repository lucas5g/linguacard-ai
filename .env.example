# OPENROUTER_API_KEY: Required for server-side OpenRouter API calls.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: Required for Prisma to connect to PostgreSQL.
# Example: "postgresql://user:password@localhost:5432/mydb?schema=public"
DATABASE_URL="MY_DATABASE_URL"
